
@model List<Employee>

<div class="container">



    <div class="d-flex justify-content-between pt-5">
        <h3>Employees</h3>
        <form method="get" asp-controller="Employee">
        <div class="d-flex gap-4">
            <input name="searchEmployee"  type="text" class="form-control" placeholder="Search By First Name" />
            <button  asp-action="Index" class="btn btn-primary">Search</button>
        </div>
        </form>
    </div>

    <div class="pt-5">
        <table class="table table-bordered text-center">
            <thead>
                <tr class="">
                    <td>
                        ID
                    </td>
                    <td>
                        First Name
                    </td>
                    <td>
                        Last Name
                    </td>
                    <td>
                        Email Address
                    </td>
                    <td>
                        Phone Number
                    </td>
                    <td>
                        Status
                    </td>
                    <td>
                        Actions
                    </td>
                </tr>
            </thead>
            <tbody>
                @foreach(var employee in Model)
                {
                    <tr class="">
                        <td class="py-4">@employee.Id</td>
                        <td class="py-4">@employee.FirstName</td>
                        <td class="py-4">@employee.LastName</td>
                        <td class="py-4">@employee.Email</td>
                        <td class="py-4">@employee.Phone</td>

                            @if (employee.Status == "Active")
                            {
                                <td class="text-success fw-bold py-4">@employee.Status</td>
                            }
                            else
                            {
                                <td class="text-danger fw-bold py-4">@employee.Status</td>
                            }

                        <td class="py-4">
                            <a asp-controller="Employee" asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-primary">Edit</a>
                            <a asp-controller="Employee" asp-action="Delete" asp-route-id="@employee.Id" class="btn btn-danger">Delete</a>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>