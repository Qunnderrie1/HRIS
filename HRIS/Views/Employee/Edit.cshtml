@{
}

@model Employee

<div class="vh-100 flex-column w-100 d-flex align-items-center justify-content-center">
    <h3 class="pb-5">Update Employee </h3>
    <form method="post" asp-action="Create" asp-controller="Employee" class="d-flex flex-column gap-4">

        <div class=" d-flex gap-4 ">
            <input asp-for="FirstName" class="form-control" placeholder="First Name" />
            <input asp-for="LastName" class="form-control" placeholder="Last Name" />
        </div>
        <div class=" d-flex gap-4 ">
            <input asp-for="Email" type=" email" class="form-control" placeholder="Email Address" />
        </div>
        <div class=" d-flex gap-4 ">
            <input asp-for="Phone" class=" form-control" placeholder="Phone" />
        </div>
        <div class=" d-flex gap-4 ">
            <select asp-for="Status" class=" form-select">
                <option value="">Choose Status</option>
                <option value="Active">Hired</option>
                <option value="InActive">Terminated</option>
            </select>
        </div>
        <button type="submit" asp-controller="Employee" class="btn btn-primary">Update</button>
    </form>
</div>